{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "skipLibCheck": true,
    "outDir": "dist-tsmc",
    "rootDir": "tsmc",
    "plugins": [{ "transform": "ts-mixin-class", "transformProgram": true }]
  },
  "include": ["tsmc"]
}
