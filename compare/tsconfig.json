{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "esModuleInterop": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "strict": false,
    "noEmitOnError": false,
    "skipLibCheck": true,
    "outDir": "dist",
    "rootDir": "src",
    "plugins": [{ "transform": "ts-mixin-class", "transformProgram": true }]
  },
  "include": ["src"]
}
