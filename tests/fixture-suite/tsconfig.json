{
    "compilerOptions": {
        "target": "ES2022",
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "lib": [
            "ES2022",
            "DOM"
        ],
        "strict": true,
        "noUnusedLocals": true,
        // Stricter import discipline for the whole corpus: type-only imports must be
        // `import type`, everything else is emitted verbatim — this keeps the transform's
        // own INJECTED helper import (`import { defineMixinClass as …, type AnyConstructor,
        // … }`) honest about its type/value split on every fixture build.
        "verbatimModuleSyntax": true,
        "useDefineForClassFields": false,
        "skipLibCheck": true,
        "rootDir": "src",
        "outDir": "dist/standard",
        "declaration": true,
        "plugins": [
            {
                "transform": "ts-mixin-class",
                "transformProgram": true
            },
            {
                "name": "ts-mixin-class/language-service-plugin"
            }
        ],
        "experimentalDecorators": false
    },
    "include": [
        "src/**/*.ts"
    ]
}
