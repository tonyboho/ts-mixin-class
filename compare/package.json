{
    "name": "mixin-libs-compare",
    "private": true,
    "type": "module",
    "description": "Empirical runtime comparison of TypeScript mixin libraries (not published).",
    "scripts": {
        "prepare": "ts-patch install -s",
        "build": "tspc -p tsconfig.json; exit 0",
        "compare": "npm run build && node run.mjs",
        "conflict": "tspc -p tsconfig.conflict.json"
    },
    "devDependencies": {
        "ts-mixin-class": "0.0.9",
        "ts-patch": "4.0.1",
        "typescript": "6.0.3",
        "reflect-metadata": "^0.2.2",
        "ts-mixer": "6.0.4",
        "typescript-mix": "3.1.3",
        "mixwith": "0.1.1",
        "mixin-types": "1.1.1",
        "polytype": "0.17.0",
        "@open-wc/dedupe-mixin": "2.0.1",
        "typed-mixins": "1.0.0",
        "@alizurchik/ts-mixin": "1.0.2",
        "mixedin": "0.5.0",
        "typescript-mixin": "1.0.3"
    }
}